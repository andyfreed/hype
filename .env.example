# ---------------------------------------------------------------------------
# Database (PostgreSQL — Supabase)
# ---------------------------------------------------------------------------
# Used by Prisma. The app's read path (profile pages, metadata) works WITHOUT
# a database in mock mode; the DB is only required for the persistence endpoint
# (POST /api/trader/[address]).
#
# Supabase project: "hype"  (ref: etqhrwvgoawknzzmturu)
# Grab the password from: Supabase Dashboard → Project → Settings → Database.
#
# DATABASE_URL = pooled connection (Supavisor, port 6543) — used at runtime.
#   Safe for serverless/Vercel. Note the ?pgbouncer=true flag.
# DIRECT_URL   = direct connection (port 5432) — used for migrations only.
DATABASE_URL="postgresql://postgres.etqhrwvgoawknzzmturu:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.etqhrwvgoawknzzmturu:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Local dev without Supabase? You can instead point at a local Postgres:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hype?schema=public"

# ---------------------------------------------------------------------------
# Hyperliquid API
# ---------------------------------------------------------------------------
# Public info endpoint. See https://hyperliquid.gitbook.io/hyperliquid-docs
HYPERLIQUID_API_URL="https://api.hyperliquid.xyz"

# When "true" the app serves deterministic mock trading data so the UI works
# immediately with no external calls. Set to "false" to hit the real API.
HYPERLIQUID_USE_MOCK="true"

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
# Absolute base URL, used to build NFT metadata image links. Optional in dev;
# the metadata route falls back to the incoming request origin.
# On Vercel, set this to your deployment URL (e.g. https://hype.vercel.app).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
